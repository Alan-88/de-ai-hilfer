# Database Configuration
# Prefer split fields for local development. If DATABASE_URL is set, it takes precedence.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=de_ai_hilfer
DB_USER=server
DB_PASSWORD=change_me

# Optional: use a full connection string instead of the split fields above.
# DATABASE_URL=postgres://server:password@localhost:5432/de_ai_hilfer

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# OpenAI API Configuration (for New API or other OpenAI-compatible services)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=glm-4.7-flash

# Prompt configuration
PROMPT_CONFIG_PATH=./config/prompts/default.yaml
